# ══════════════════════════════════════════════════════════════════════════════
# BizPilot — inventário de variáveis de ambiente (Vercel → Settings → Env Vars)
# Copie para .env.local no dev. NUNCA commitar valores reais.
# "Obrigatória" = app quebra ou rota devolve 500 sem ela.
# "Opcional" = a feature correspondente desliga silenciosamente sem ela.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (OBRIGATÓRIAS) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: só no servidor (sem NEXT_PUBLIC_). Toda rota /api depende dela.
SUPABASE_SERVICE_ROLE_KEY=

# ── Segredo interno (OBRIGATÓRIA) ─────────────────────────────────────────────
# Autentica Windmill → Next (/api/calendar/*, /api/campaigns/[id]/*, purge,
# connection-webhook, expire-subscriptions...). O MESMO valor precisa estar na
# variável u/bevervansomarcio/bizpilot/INTERNAL_API_SECRET do Windmill.
INTERNAL_API_SECRET=

# ── OpenAI (OBRIGATÓRIA para o produto funcionar) ─────────────────────────────
# Usada em embeddings da KB, geração de agentes, support-chat. O pipeline de
# mensagens usa a cópia no Windmill (u/bevervansomarcio/bizpilot/OPENAI_API_KEY).
OPENAI_API_KEY=

# ── Evolution API (WhatsApp via QR) ───────────────────────────────────────────
EVOLUTION_API_URL=https://evo.exemplo.com.br
EVOLUTION_API_KEY=

# ── Windmill ──────────────────────────────────────────────────────────────────
# URL do webhook do flow "bot" (recebe eventos da Evolution e do canal Meta).
WINDMILL_WEBHOOK_URL=
# Token dedicado ao script campaign_sender (disparo de campanhas).
WINDMILL_CAMPAIGN_TOKEN=

# ── App ───────────────────────────────────────────────────────────────────────
# Base pública do app (links em e-mails e chamadas internas do Windmill).
APP_BASE_URL=https://bizpilot.com.br

# ── Billing Efí (Pix + cartão) — sem elas o checkout fica "indisponível" ─────
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
# Certificado .p12 da Efí convertido: base64 -w0 certificado.p12
EFI_CERT_BASE64=
EFI_PIX_KEY=
# Segredo aleatório que compõe a URL do webhook (rotacionável).
EFI_WEBHOOK_SECRET=
EFI_SANDBOX=false
NEXT_PUBLIC_EFI_PAYEE_CODE=
NEXT_PUBLIC_EFI_SANDBOX=false

# ── WhatsApp Meta Oficial (Cloud API) ─────────────────────────────────────────
# OBRIGATÓRIA se houver agente no canal Meta: sem ela o webhook rejeita todo
# POST (fail-closed) e o canal Meta para de receber mensagens.
META_APP_SECRET=

# ── Google OAuth (Calendar + Gmail do cliente) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Cifra os refresh tokens do Google salvos em integrations (32 bytes hex).
INTEGRATIONS_ENCRYPTION_KEY=

# ── E-mail transacional do sistema (avisos de queda de WhatsApp etc.) ─────────
SYSTEM_SMTP_HOST=
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_USER=
SYSTEM_SMTP_PASS=
SYSTEM_SMTP_SECURE=false
SYSTEM_EMAIL_FROM="BizPilot <no-reply@bizpilot.com.br>"

# ── Observabilidade ───────────────────────────────────────────────────────────
NEXT_PUBLIC_BUGSINK_DSN=

# ── Analytics (opcional — Umami/Plausible self-host, sem cookies/LGPD-ok) ────
# Ex.: subir Umami na VPS (docker run -d -p 3210:3000 ... ghcr.io/umami-software/umami)
# e apontar: SRC=https://analytics.bizpilot.com.br/script.js, WEBSITE_ID=<uuid do site>
NEXT_PUBLIC_ANALYTICS_SRC=
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=

# ── Afiliados (dormante até ativar) ───────────────────────────────────────────
AWIN_ADVERTISER_ID_ML=
AWIN_PUBLISHER_ID=
SERPER_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# Lado Windmill (workspace foodsnap, variáveis em u/bevervansomarcio/bizpilot/):
#   OPENAI_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, APP_BASE_URL,
#   INTERNAL_API_SECRET — usadas pelos scripts do pipeline (windmill/*.ts).
# ══════════════════════════════════════════════════════════════════════════════
